digraph test_e2e {
  graph [pipeline_id="test-e2e-001"]

  start [shape=Mdiamond label="BEGIN"]
  check [shape=parallelogram label="validate input"]
  decide [shape=diamond label="check status"]
  process [shape=parallelogram label="process data"]
  retry_node [shape=parallelogram label="retry handler" max_retries="2"]
  done [shape=Msquare label="END"]

  start -> check
  check -> decide [label="ok" condition="$last_status = success"]
  check -> retry_node [label="retry" condition="$last_status != success"]
  decide -> process [label="success" condition="$last_status = success"]
  decide -> done [label="fail" condition="$last_status != success"]
  process -> done
  retry_node -> decide [label="retry_back"]
}
