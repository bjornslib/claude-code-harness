        style="filled"
    ];

    // ════════════════════════════════════════════════════════════
    // EDGES
    // ════════════════════════════════════════════════════════════

    // Phase 1: Planner
    start -> research_codebase [label="begin"];
    research_codebase -> research_domain [label="codebase_mapped"];
    research_domain -> write_ts [label="domain_researched"];
    write_ts -> gate_planner [label="ts_written"];
    gate_planner -> review_planner [label="guardian_ok"];
    review_planner -> decide_planner [label="human_reviewed"];
    decide_planner -> red_tests [condition="pass" label="ts_approved"];
    decide_planner -> write_ts [condition="fail" label="rework_ts"];

    // Phase 2: Red (failing tests)
    red_tests -> gate_red [label="tests_written"];
    gate_red -> green_impl [label="tests_fail_confirmed"];

    // Phase 3: Green (implementation)
    green_impl -> gate_green [label="impl_done"];
    gate_green -> validate [label="tests_pass_confirmed"];

    // Phase 4: Validator
    validate -> gate_validate [label="validation_done"];
    gate_validate -> review_final [label="guardian_ok"];
    review_final -> decide_final [label="human_reviewed"];
    decide_final -> fix_red [condition="pass" label="gaps_to_fix"];
    decide_final -> green_impl [condition="fail" label="rework_impl"];

    // Phase 5: Fix-it (close validation gaps)
    fix_red -> fix_gate_red [label="fix_tests_written"];
    fix_gate_red -> fix_green [label="fix_tests_fail_confirmed"];
    fix_green -> fix_gate_green [label="fix_impl_done"];
    fix_gate_green -> fix_validate [label="fix_tests_pass"];
    fix_validate -> fix_gate_validate [label="fix_validated"];
    fix_gate_validate -> fix_review [label="guardian_ok"];
    fix_review -> rsch_red [label="researcher_fix_needed"];

    // Phase 6: Researcher fix (DSPy ReAct)
    rsch_red -> rsch_gate_red [label="react_tests_written"];
    rsch_gate_red -> rsch_green [label="react_tests_fail_confirmed"];
    rsch_green -> rsch_gate_green [label="react_impl_done"];
    rsch_gate_green -> rsch_validate [label="react_tests_pass"];
    rsch_validate -> rsch_gate_validate [label="react_validated"];
    rsch_gate_validate -> rsch_review [label="guardian_ok"];
    rsch_review -> pipeline_exit [label="researcher_approved"];
}