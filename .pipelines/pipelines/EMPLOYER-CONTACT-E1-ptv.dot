// Generated from template: planner-tdd-validated v1.0
// PRD: PRD-EMPLOYER-CONTACT-001 | Epic: E1-research-agent
// Pattern: Planner → Red (TDD) → Green (Impl) → Validator
// Follows Anthropic's recommended Planner-Worker-Validator architecture

digraph "PRD-EMPLOYER-CONTACT-001-E1-research-agent" {
    graph [
        label="Planner-TDD-Validator: Employer Contact Research Agent (DSPy + Perplexity + Web Search)"
        labelloc="t"
        fontsize=16
        rankdir="TB"
        pipeline_id="PRD-EMPLOYER-CONTACT-001-E1-research-agent-ptv"
        prd_ref="PRD-EMPLOYER-CONTACT-001"
        cobuilder_root="/Users/theb/Documents/Windsurf/cobuilder-harness"
        target_dir="/Users/theb/Documents/Windsurf/zenagent"
        _template="planner-tdd-validated"
        _template_version="1.0"
    ];

    node [fontname="Helvetica" fontsize=11 style=filled];
    edge [fontname="Helvetica" fontsize=9 arrowhead=vee];

    // ════════════════════════════════════════════════════════════
    // START
    // ════════════════════════════════════════════════════════════
    start [
        label="START\nPRD-EMPLOYER-CONTACT-001"
        handler="start"
        shape=Mdiamond
        fillcolor=green
        status=pending
    ];

    // ════════════════════════════════════════════════════════════
    // PHASE 1: PLANNER — Research BS, produce TS for this epic
    //   Reads the Business Spec, researches the codebase and
    //   domain patterns, then writes a Technical Spec for the epic.
    // ════════════════════════════════════════════════════════════
    research_codebase [
        label="Research: Codebase Analysis"
        handler="research"
        shape=tab
        fillcolor=lightcyan
        status=pending
        solution_design="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/prds/employer-contact-search/PRD-EMPLOYER-CONTACT-001.md"
        prd_ref="PRD-EMPLOYER-CONTACT-001"
        llm_profile="alibaba-glm5"
        research_queries="codebase structure for Employer Contact Research Agent (DSPy + Perplexity + Web Search), existing patterns, database schema, API endpoints, test infrastructure"
        downstream_node="research_domain"
        prompt="PLANNER PHASE: Research the target codebase at /Users/theb/Documents/Windsurf/zenagent for epic E1-research-agent: Employer Contact Research Agent. MANDATORY: Invoke Skill('dspy-development') before any DSPy design decisions. (1) Read the BS at /Users/theb/Documents/Windsurf/cobuilder-harness/docs/prds/employer-contact-search/PRD-EMPLOYER-CONTACT-001.md — focus on Section 5 (Research Agent Specification). (2) Explore the zenagent codebase: find existing DSPy modules, Perplexity integrations, PydanticAI agents, database models (especially university_contacts pattern). (3) Identify: existing employer_contacts table or similar, Supabase connection patterns, background_tasks integration. (4) Document: file paths, existing DSPy patterns, Perplexity API usage, database schema. Write structured findings to evidence JSON."
    ];

    research_domain [
        label="Research: Domain Patterns"
        handler="research"
        shape=tab
        fillcolor=lightcyan
        status=pending
        solution_design="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/prds/employer-contact-search/PRD-EMPLOYER-CONTACT-001.md"
        prd_ref="PRD-EMPLOYER-CONTACT-001"
        llm_profile="alibaba-glm5"
        research_queries="domain patterns for Employer Contact Research Agent (DSPy + Perplexity + Web Search), framework best practices, library APIs, similar implementations"
        downstream_node="write_ts"
        prompt="PLANNER PHASE: Research domain patterns for the employer contact research agent. MANDATORY: Invoke Skill('dspy-development') and Skill('research-first'). (1) Use Context7 to research DSPy module patterns (Signatures, Modules, Optimizers) and Perplexity Deep Research API. (2) Research via Perplexity: how to build an employer contact finder using Perplexity API + web search (not just Perplexity alone). (3) Research contact classification patterns: general vs named_poc, confidence scoring algorithms. (4) Identify testing patterns: how to test DSPy modules (mock vs real API), how to test web search results, how to test contact deduplication. (5) Document: DSPy module design, Perplexity + web search combo approach, confidence scoring formula, test fixtures. Write findings to evidence JSON."
    ];

    write_ts [
        label="Planner: Write Technical Spec"
        handler="codergen"
        shape=box
        fillcolor=lightyellow
        status=pending
        bead_id="PLACEHOLDER-PLANNER"
        worker_type="solution-design-architect"
        sd_path="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/prds/employer-contact-search/PRD-EMPLOYER-CONTACT-001.md"
        prd_ref="PRD-EMPLOYER-CONTACT-001"
        llm_profile="alibaba-glm5"
        acceptance="TS covers: module design, API contracts, data model changes, file-by-file implementation plan, test strategy, acceptance criteria mapping"
        prompt="PLANNER PHASE: Write a Technical Spec at /Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/employer-contact-search/SD-EMPLOYER-CONTACT-E1.md. MANDATORY: Invoke Skill('dspy-development'). Use the BS and both research evidence files. CRITICAL: Follow Clean Architecture (feature-first) from BS Section 13 and docs/AGENCHECK_CLEANUP.md. The employer_research/ directory must have: domain.py (models, no I/O), classifier.py (pure logic), service.py (orchestration), repository.py (Supabase adapter), researcher.py (DSPy/Perplexity/web search adapter), router.py (entrypoint). Dependencies flow inward: entrypoints → service_layer → domain ← adapters. The TS must include: (1) DSPy Module design: EmployerContactResearcher(dspy.Module) in researcher.py with Signatures for search, classify, score, deduplicate. (2) Dual-source research: Perplexity Deep Research API + web search (Brave/Google). NOT Perplexity alone. (3) Data model: employer_contacts table (BS Section 7.1), Supabase in repository.py. (4) Classification + scoring in domain layer (no API deps). (5) File-by-file plan matching the feature-first structure. (6) Test strategy per layer. (7) BS Section 5 acceptance criteria mapped to tests."
    ];

    // ── Planner gate: Guardian reviews TS quality ──
    gate_planner [
        label="TS Quality Gate"
        handler="wait.cobuilder"
        shape=hexagon
        fillcolor=purple
        status=pending
        gate_type="e2e"
        summary_ref="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/employer-contact-search/SD-EMPLOYER-CONTACT-E1.md"
        bead_id="PLACEHOLDER-PLANNER"
    ];

    review_planner [
        label="Human Reviews TS"
        handler="wait.human"
        shape=hexagon
        fillcolor=red
        status=pending
        gate="technical"
        mode="technical"
    ];

    decide_planner [
        label="TS Approved?"
        handler="conditional"
        shape=diamond
        fillcolor=lightyellow
        status=pending
    ];

    // ════════════════════════════════════════════════════════════
    // PHASE 2: RED — Write failing tests against the TS
    //   TDD test engineer reads the TS, writes tests that MUST
    //   FAIL because the implementation doesn't exist yet.
    //   Tests define the contract; implementation fills it.
    // ════════════════════════════════════════════════════════════
    red_tests [
        label="RED: Write Failing Tests"
        handler="codergen"
        shape=box
        fillcolor="#ffcccc"
        status=pending
        bead_id="PLACEHOLDER-IMPL"
        worker_type="tdd-test-engineer"
        sd_path="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/employer-contact-search/SD-EMPLOYER-CONTACT-E1.md"
        prd_ref="PRD-EMPLOYER-CONTACT-001"
        llm_profile="anthropic-sonnet46"
        acceptance="Tests written, ALL tests FAIL (red), tests cover every TS acceptance criterion, test command runs without import errors"
        prompt="RED PHASE (TDD): MANDATORY: Invoke Skill('dspy-development') and Skill('test-driven-development'). Read the TS at /Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/employer-contact-search/SD-EMPLOYER-CONTACT-E1.md. Write pytest tests for the DSPy employer contact research agent. RULES: (1) Every BS acceptance criterion MUST have at least one test. (2) Tests MUST fail — the DSPy modules don't exist yet. (3) Test categories: (a) contact classification (general vs named_poc), (b) confidence scoring (source reliability weighting), (c) contact deduplication (phone/email matching), (d) contact prioritisation (PRD Section 5.2 priority tiers), (e) integration: Perplexity API mock + web search mock → full pipeline. (4) Use pytest fixtures with mock Perplexity/web search responses. (5) Run 'pytest tests/ -v' — verify ALL tests FAIL. Report test file paths and failure count."
    ];

    // ── Red gate: verify tests actually fail ──
    gate_red [
        label="Red Verification Gate"
        handler="wait.cobuilder"
        shape=hexagon
        fillcolor=purple
        status=pending
        gate_type="unit"
        summary_ref="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/employer-contact-search/SD-EMPLOYER-CONTACT-E1.md"
        bead_id="PLACEHOLDER-IMPL"
    ];

    // ════════════════════════════════════════════════════════════
    // PHASE 3: GREEN — Implement to make tests pass
    //   Implementation worker reads the TS and the failing tests,
    //   then writes the minimal code to make all tests pass.
    // ════════════════════════════════════════════════════════════
    green_impl [
        label="GREEN: Implement to Pass"
        handler="codergen"
        shape=box
        fillcolor="#ccffcc"
        status=pending
        bead_id="PLACEHOLDER-IMPL"
        worker_type="backend-solutions-engineer"
        sd_path="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/employer-contact-search/SD-EMPLOYER-CONTACT-E1.md"
        prd_ref="PRD-EMPLOYER-CONTACT-001"
        llm_profile="anthropic-sonnet46"
        acceptance="ALL tests pass (green), implementation follows TS architecture, no test modifications allowed"
        prompt="GREEN PHASE (TDD): MANDATORY: Invoke Skill('dspy-development') and Skill('research-first') for current DSPy and Perplexity API patterns. Read the TS and failing tests. Implement the DSPy employer contact research agent. RULES: (1) Do NOT modify test files. (2) Implement: EmployerContactResearcher(dspy.Module) with dual-source research (Perplexity Deep Research API + web search via Brave/Google). (3) Implement contact classification, confidence scoring, deduplication, and prioritisation per TS. (4) Implement employer_contacts Supabase storage. (5) Follow TS architecture exactly. (6) Run 'pytest tests/ -v' — ALL tests must PASS. (7) If a test seems wrong, document why but do NOT change it."
    ];

    // ── Green gate: verify tests actually pass ──
    gate_green [
        label="Green Verification Gate"
        handler="wait.cobuilder"
        shape=hexagon
        fillcolor=purple
        status=pending
        gate_type="unit"
        summary_ref="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/employer-contact-search/SD-EMPLOYER-CONTACT-E1.md"
        bead_id="PLACEHOLDER-IMPL"
    ];

    // ════════════════════════════════════════════════════════════
    // PHASE 4: VALIDATOR — Independent check against BS + TS
    //   Validator reads the BS, TS, and implementation.
    //   Scores against acceptance criteria from BOTH documents.
    //   Does NOT trust the worker's self-report.
    // ════════════════════════════════════════════════════════════
    validate [
        label="Validator: BS + TS Check"
        handler="codergen"
        shape=box
        fillcolor="#ccccff"
        status=pending
        bead_id="PLACEHOLDER-IMPL"
        worker_type="validation-test-agent"
        sd_path="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/employer-contact-search/SD-EMPLOYER-CONTACT-E1.md"
        prd_ref="PRD-EMPLOYER-CONTACT-001"
        llm_profile="anthropic-sonnet46"
        acceptance="Validation score >= 0.70, all BS acceptance criteria checked, all TS contracts verified, implementation matches both specs"
        prompt="VALIDATOR PHASE: MANDATORY: Invoke Skill('dspy-development') to understand DSPy patterns before reviewing. You are an independent auditor — you have NOT seen worker output. (1) Read BS Section 5 (Research Agent Spec) — extract acceptance criteria: exhaustive contact list, classification, confidence scoring, source attribution. (2) Read TS — extract technical contracts: DSPy module signatures, Perplexity + web search dual-source, Supabase storage. (3) Read implementation: verify DSPy modules exist and match TS signatures. (4) Run 'pytest tests/ -v' yourself. (5) Score each BS criterion 0.0-1.0: (a) Does research produce contacts from multiple sources? (b) Are contacts classified correctly? (c) Is confidence scoring reasonable? (d) Is deduplication working? (e) Is prioritisation per PRD Section 5.2? (6) Check: error handling for API failures, rate limiting, empty results. (7) ACCEPT threshold: 0.70."
    ];

    // ── Final validation gate ──
    gate_validate [
        label="Validation Gate"
        handler="wait.cobuilder"
        shape=hexagon
        fillcolor=purple
        status=pending
        gate_type="e2e"
        summary_ref="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/employer-contact-search/SD-EMPLOYER-CONTACT-E1.md"
        bead_id="PLACEHOLDER-IMPL"
    ];

    review_final [
        label="Human Final Review"
        handler="wait.human"
        shape=hexagon
        fillcolor=red
        status=pending
        gate="e2e"
        mode="technical"
    ];

    decide_final [
        label="Epic Complete?"
        handler="conditional"
        shape=diamond
        fillcolor=lightyellow
        status=pending
    ];

    // ════════════════════════════════════════════════════════════
    // EXIT
    // ════════════════════════════════════════════════════════════
    pipeline_exit [
        label="Complete"
        handler="exit"
        shape=Msquare
        fillcolor=darkgreen
        status=pending
    ];

    // ════════════════════════════════════════════════════════════
    // EDGES
    // ════════════════════════════════════════════════════════════

    // Phase 1: Planner
    start -> research_codebase [label="begin"];
    research_codebase -> research_domain [label="codebase_mapped"];
    research_domain -> write_ts [label="domain_researched"];
    write_ts -> gate_planner [label="ts_written"];
    gate_planner -> review_planner [label="guardian_ok"];
    review_planner -> decide_planner [label="human_reviewed"];
    decide_planner -> red_tests [condition="pass" label="ts_approved"];
    decide_planner -> write_ts [condition="fail" label="rework_ts"];

    // Phase 2: Red (failing tests)
    red_tests -> gate_red [label="tests_written"];
    gate_red -> green_impl [label="tests_fail_confirmed"];

    // Phase 3: Green (implementation)
    green_impl -> gate_green [label="impl_done"];
    gate_green -> validate [label="tests_pass_confirmed"];

    // Phase 4: Validator
    validate -> gate_validate [label="validation_done"];
    gate_validate -> review_final [label="guardian_ok"];
    review_final -> decide_final [label="human_reviewed"];
    decide_final -> pipeline_exit [condition="pass" label="epic_complete"];
    decide_final -> green_impl [condition="fail" label="rework_impl"];
}