digraph "PRD-GASCITY-INT-001-HANDSON" {
    graph [
        pipeline_id="gascity-int-001-handson"
        prd_ref="PRD-GASCITY-INT-001"
        label="GasCity Hands-On Spike — Build, Validate TS Design, Design Roles"
        cobuilder_root="/Users/theb/Documents/Windsurf/cobuilder-harness"
        target_dir="/Users/theb/Documents/Windsurf/cobuilder-harness"
    ]

    node [style=filled]
    edge [arrowhead=vee]

    // ══════════════════════════════════════════════
    // START
    // ══════════════════════════════════════════════
    start [label="Start"
           handler="start"
           shape=Mdiamond
           fillcolor=green
           status=pending]

    // ══════════════════════════════════════════════
    // PHASE 1: Build GasCity, bootstrap city, run swarm
    //   This is HANDS-ON: build binary, gc init, gc start,
    //   register rig, verify agents spawn and claim work.
    //   The running city is a prerequisite for P0 tests.
    // ══════════════════════════════════════════════
    research_build [label="Build gc + Run Swarm City"
                    handler="research"
                    shape=tab
                    fillcolor=lightcyan
                    status=pending
                    solution_design="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/gascity-integration/SD-GASCITY-INT-001.md"
                    prd_ref="PRD-GASCITY-INT-001"
                    llm_profile="alibaba-glm5"
                    research_queries="Go build gc binary, gc init city, swarm pack, gc rig add, gc start, gc session list, bd create test task, verify agent claims work"
                    downstream_node="research_context"
                    prompt="HANDS-ON: Build and run GasCity locally from workspace/gascity/. This is not source reading — you must EXECUTE commands and document results. (1) cd workspace/gascity && cat Makefile — find build target. Run make build. (2) Verify binary: $(go env GOPATH)/bin/gc version — must show 'gas' not 'graphviz'. (3) gc init ~/cobuilder-city && cd ~/cobuilder-city. (4) Copy swarm pack: cp -r workspace/gascity/examples/swarm/packs ~/cobuilder-city/packs && cp workspace/gascity/examples/swarm/city.toml ~/cobuilder-city/. (5) gc rig add /Users/theb/Documents/Windsurf/cobuilder-harness. (6) gc start — capture controller output. (7) gc session list — verify agents spawned. (8) bd create 'Hello world test' && bd ready — verify bead visible. (9) gc stop. Document EVERY command and output. If build fails (Go version, deps), document the error. Write evidence JSON with verdict: CITY_RUNNING or BUILD_FAILED."]

    // ══════════════════════════════════════════════
    // PHASE 2: P0 — Test context persistence + multi-gate
    //   These validate our TS design assumptions.
    //   Requires running city from Phase 1.
    // ══════════════════════════════════════════════
    research_context [label="P0: Mayor Context Across Steps"
                      handler="research"
                      shape=tab
                      fillcolor=lightcyan
                      status=pending
                      solution_design="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/gascity-integration/SD-GASCITY-INT-001.md"
                      prd_ref="PRD-GASCITY-INT-001"
                      llm_profile="alibaba-glm5"
                      research_queries="GasCity session persistence across formula steps, molecule step execution, tmux session reuse, named_session always mode, crew agent context"
                      downstream_node="research_multigate"
                      prompt="P0 BLOCKER: Does a GasCity agent maintain conversation context across formula steps? (1) If city is running: create a 2-step formula where step-1 defines a variable and step-2 references it. Run via gc sling and observe. (2) Read workspace/gascity/internal/convergence/handler.go — trace HandleWispClosed: when step N completes, how is step N+1 delivered to the agent? Same session or new? (3) Read workspace/gascity/cmd/gc/controller.go — convergence tick: does it reuse the existing session or create fresh? (4) Check named_session mode='always' (deacon uses this) — does always-on session maintain context? (5) Read mol-idea-to-plan step 'human-clarify': it says 'Present questions directly in the live conversation' — this implies SAME session. Verify. VERDICT REQUIRED: MAINTAINS_CONTEXT or FRESH_SESSION with evidence."]

    research_multigate [label="P0: Multi-Gate Formula Test"
                        handler="research"
                        shape=tab
                        fillcolor=lightcyan
                        status=pending
                        solution_design="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/gascity-integration/SD-GASCITY-INT-001.md"
                        prd_ref="PRD-GASCITY-INT-001"
                        llm_profile="alibaba-glm5"
                        research_queries="GasCity formula multiple human gates, convergence step pause, human-clarify implementation, controller gate handling, formula step types"
                        downstream_node="refine_ts_validation"
                        prompt="P0 BLOCKER: Do multi-gated formulas work? (1) Read mol-idea-to-plan.formula.toml — it has ONE human-clarify gate. But our enhanced Mayor needs THREE (BS-review, TS-review, direction-approval). (2) Read workspace/gascity/internal/convergence/*.go — is human-clarify a special step type or just a prompt instruction? Can a formula have multiple? (3) If city running: create mol-test-gates.formula.toml with 3 steps that each say 'Ask the human: [question]'. Instantiate and observe. (4) Read workspace/gascity/docs/reference/formula.md — convergence-specific fields: evaluate_prompt, convergence=true. Can non-convergence steps pause for human input? (5) Alternative: could each human gate be a convergence step with evaluate_prompt that waits for human signal? VERDICT REQUIRED: MULTI_GATE_WORKS or SINGLE_GATE_ONLY with evidence and workaround if single-gate."]

    // ── Refine: Validate TS design against hands-on findings ──
    refine_ts_validation [label="Refine: Validate TS Against Reality"
                          handler="refine"
                          shape=note
                          fillcolor=lightgreen
                          status=pending
                          solution_design="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/gascity-integration/SD-GASCITY-INT-001.md"
                          evidence_path="/Users/theb/Documents/Windsurf/cobuilder-harness/.pipelines/pipelines/evidence/research_build/research-findings.json"
                          prd_ref="PRD-GASCITY-INT-001"
                          llm_profile="alibaba-glm5"
                          prompt="Compare SD-GASCITY-INT-001.md assumptions against hands-on findings from all 3 research nodes. (1) Read all evidence files. (2) For each TS assumption, mark CONFIRMED or INVALIDATED with evidence. Key assumptions to validate: (a) subprocess provider works for Claude sessions, (b) gc poke triggers immediate reconcile, (c) pool agents can claim beads atomically, (d) bead metadata can carry scoring JSON, (e) convergence evaluate_prompt can run quality scoring, (f) session context persists across formula steps, (g) multiple human gates work in formulas. (3) Update SD-GASCITY-INT-001.md: mark each assumption as confirmed/invalidated. Add a 'Hands-On Validation Results' section. (4) If any critical assumption is invalidated, propose alternative design in the document."]

    // ── P0 Gate: Guardian reviews TS validation ──
    gate_p0 [label="TS Validation Gate"
             handler="wait.cobuilder"
             shape=hexagon
             fillcolor=purple
             status=pending
             gate_type="e2e"
             summary_ref="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/gascity-integration/SD-GASCITY-INT-001.md"
             bead_id="claude-harness-setup-bf4b"]

    review_p0 [label="Human Reviews TS Validity"
               handler="wait.human"
               shape=hexagon
               fillcolor=red
               status=pending
               gate="technical"
               mode="technical"]

    decide_p0 [label="TS Valid?"
               handler="conditional"
               shape=diamond
               fillcolor=lightyellow
               status=pending]

    // ══════════════════════════════════════════════
    // PHASE 3: Design enhanced Mayor + Architect
    //   Sequential: Mayor first (defines the planning flow),
    //   Architect second (consumes Mayor's output)
    // ══════════════════════════════════════════════
    design_mayor [label="Design: Enhanced Mayor Formula"
                  handler="codergen"
                  shape=box
                  fillcolor=lightyellow
                  status=pending
                  bead_id="claude-harness-setup-8r1k"
                  worker_type="solution-design-architect"
                  sd_path="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/gascity-integration/SD-GASCITY-INT-001.md"
                  prd_ref="PRD-GASCITY-INT-001"
                  llm_profile="alibaba-glm5"
                  acceptance="Enhanced mol-idea-to-plan formula with BS-review gate, TS-review gate, acceptance-test-generation step, direction-approval gate. Adapts to P0 context/multi-gate findings."
                  prompt="Design an enhanced mol-idea-to-plan formula for the cobuilder-verified pack. Read the P0 evidence files for context/multi-gate verdicts FIRST. Create: (1) mol-cobuilder-plan.formula.toml with human gates for BS-review (after PRD + review legs), TS-review (after design), direction-approval (after alignment). Adapt gate implementation to P0 findings. (2) If FRESH_SESSION: each step reads/writes artifacts, no context dependency. If MAINTAINS_CONTEXT: leverage conversation. (3) Add acceptance-test-generation step before create-beads (blind Gherkin rubrics). (4) Write ENHANCED-MAYOR-DESIGN.md at docs/sds/gascity-integration/ with rationale."]

    design_architect [label="Design: Architect Agent"
                      handler="codergen"
                      shape=box
                      fillcolor=lightyellow
                      status=pending
                      bead_id="claude-harness-setup-iark"
                      worker_type="solution-design-architect"
                      sd_path="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/gascity-integration/SD-GASCITY-INT-001.md"
                      prd_ref="PRD-GASCITY-INT-001"
                      llm_profile="alibaba-glm5"
                      acceptance="Architect agent definition, prompt template, mol-architect-work formula with research-refine-codergen pipeline, integration with enhanced Mayor output."
                      prompt="Design a rig-scoped Architect agent for packs/cobuilder-verified/. Reads the enhanced Mayor design FIRST. Create: (1) Agent definition in pack.toml (scope=rig, work_query for architect beads). (2) prompts/architect.md.tmpl — research→refine→TS workflow. (3) mol-architect-work.formula.toml: research-codebase, research-patterns, refine-findings, write-ts, human-review-ts. (4) Integration: Mayor's create-beads creates an architect bead → gc sling triggers architect formula. (5) Write ARCHITECT-AGENT-DESIGN.md at docs/sds/gascity-integration/. Consider parallel solutioning (multiple architect legs, best TS wins)."]

    // ── Design validation chain ──
    gate_design [label="Design Validation Gate"
                 handler="wait.cobuilder"
                 shape=hexagon
                 fillcolor=purple
                 status=pending
                 gate_type="e2e"
                 summary_ref="/Users/theb/Documents/Windsurf/cobuilder-harness/docs/sds/gascity-integration/ENHANCED-MAYOR-DESIGN.md"
                 bead_id="claude-harness-setup-8r1k"]

    review_design [label="Design Human Review"
                   handler="wait.human"
                   shape=hexagon
                   fillcolor=red
                   status=pending
                   gate="technical"
                   mode="technical"]

    decide_design [label="Designs Approved?"
                   handler="conditional"
                   shape=diamond
                   fillcolor=lightyellow
                   status=pending]

    // ══════════════════════════════════════════════
    // EXIT
    // ══════════════════════════════════════════════
    pipeline_exit [label="Complete"
                   handler="exit"
                   shape=Msquare
                   fillcolor=darkgreen
                   status=pending]

    // ══════════════════════════════════════════════
    // EDGES
    // ══════════════════════════════════════════════

    // Phase 1: Build + run city
    start -> research_build [label="begin"]

    // Phase 2: P0 tests (sequential, need running city)
    research_build -> research_context [label="city_running"]
    research_context -> research_multigate [label="context_verdict"]
    research_multigate -> refine_ts_validation [label="multigate_verdict"]

    // P0 gate: validate TS design against reality
    refine_ts_validation -> gate_p0 [label="ts_validated"]
    gate_p0 -> review_p0 [label="guardian_reviewed"]
    review_p0 -> decide_p0 [label="human_reviewed"]
    decide_p0 -> design_mayor [condition="pass" label="ts_valid"]
    decide_p0 -> research_context [condition="fail" label="rework_p0"]

    // Phase 3: Design (sequential — architect depends on Mayor output)
    design_mayor -> design_architect [label="mayor_designed"]

    // Design gate
    design_architect -> gate_design [label="architect_designed"]
    gate_design -> review_design [label="guardian_reviewed"]
    review_design -> decide_design [label="human_reviewed"]
    decide_design -> pipeline_exit [condition="pass" label="approved"]
    decide_design -> design_mayor [condition="fail" label="rework"]
}
