// Generated from template: cobuilder-lifecycle v1.0
// Initiative: {{ initiative_id }}
// Self-driving CoBuilder Guardian lifecycle pipeline
// Cycle limit: {{ max_cycles }}

digraph "cobuilder-{{ initiative_id }}" {
    graph [
        label="CoBuilder Lifecycle: {{ initiative_id }}"
        labelloc="t"
        fontsize=16
        rankdir="TB"
        initiative_id="{{ initiative_id }}"
        _template="cobuilder-lifecycle"
        _template_version="1.0"
        target_dir="{{ target_dir }}"
        default_max_retry="{{ max_cycles * 7 + 10 }}"
    ];

    node [fontname="Helvetica" fontsize=11];
    edge [fontname="Helvetica" fontsize=9];

    // ================================================================
    // ENTRY
    // ================================================================
    start [
        shape=Mdiamond
        label="PARSE\n{{ initiative_id }}"
        handler="start"
        status="pending"
        style=filled
        fillcolor=lightyellow
    ];

    // ================================================================
    // RESEARCH — investigate problem domain
    // ================================================================
    research [
        shape=tab
        label="RESEARCH\nProblem Domain"
        handler="research"
        worker_type="researcher"
        llm="{{ model_research }}"
        prompt="Research the problem domain for {{ initiative_id }}. Read {{ business_spec_path }}. Identify unknowns, framework constraints, and prior art. If $previous_failures is set, focus on investigating root causes of prior failures rather than domain research. Write findings to state/{{ initiative_id }}-research.json."
        initiative_id="{{ initiative_id }}"
        status="pending"
        style=filled
        fillcolor=lightcyan
    ];

    start -> research [label="begin"];

    // ================================================================
    // REFINE — update Business Spec with research findings
    // ================================================================
    refine [
        shape=box
        label="REFINE\nBS + Constraints"
        handler="codergen"
        worker_type="solution-architect"
        llm="{{ model_refine }}"
        prompt="Read state/{{ initiative_id }}-research.json and {{ business_spec_path }}. Produce a refined Business Spec with updated acceptance criteria, constraints discovered during research, and technical spec notes. Write to state/{{ initiative_id }}-refined.md."
        initiative_id="{{ initiative_id }}"
        status="pending"
        style=filled
        fillcolor=lightyellow
    ];

    research -> refine [label="findings ready"];

    // ================================================================
    // PLAN — generate child pipeline DOT from refined BS
    // ================================================================
    plan [
        shape=box
        label="PLAN\nGenerate Pipeline"
        handler="codergen"
        worker_type="solution-architect"
        llm="{{ model_plan }}"
        prompt="Read state/{{ initiative_id }}-refined.md. Select template '{{ execution_template }}' and map tasks to workers. Generate params.yaml and instantiate the template. Write state/{{ initiative_id }}-plan.json with {dot_path, template, params}. Use: cobuilder template instantiate {{ execution_template }} --param-file params.yaml --output pipelines/{{ initiative_id }}-cycle-$cycle_count.dot"
        initiative_id="{{ initiative_id }}"
        status="pending"
        style=filled
        fillcolor=lightyellow
    ];

    refine -> plan [label="BS refined"];

{% if require_human_before_launch %}
    // ================================================================
    // WAIT.HUMAN — gate before launching child pipeline
    // ================================================================
    wait_approval [
        shape=octagon
        label="WAIT.HUMAN\nApproval Gate"
        handler="wait.human"
        gate="launch"
        prompt="Review the generated pipeline plan in state/{{ initiative_id }}-plan.json. Approve to proceed with execution."
        initiative_id="{{ initiative_id }}"
        status="pending"
        style=filled
        fillcolor=lightcoral
    ];

    plan -> wait_approval [label="plan ready"];
    wait_approval -> execute [label="approved"];
{% else %}
    plan -> execute [label="plan ready"];
{% endif %}

    // ================================================================
    // EXECUTE — spawn child pipeline runner
    // ================================================================
    execute [
        shape=house
        label="EXECUTE\nChild Pipeline"
        handler="manager_loop"
        mode="spawn_pipeline"
        pipeline_params_file="state/{{ initiative_id }}-plan.json"
        signals_dir="signals/{{ initiative_id }}"
        summarizer="true"
        timeout="7200"
        initiative_id="{{ initiative_id }}"
        status="pending"
        style=filled
        fillcolor=lightyellow
    ];

    // ================================================================
    // VALIDATE — run acceptance tests against BS
    // ================================================================
    validate [
        shape=hexagon
        label="VALIDATE\nAcceptance Tests"
        handler="wait.cobuilder"
        gate="acceptance"
        mode="business"
        initiative_id="{{ initiative_id }}"
        status="pending"
        style=filled
        fillcolor=lightyellow
    ];

    execute -> validate [label="execution complete"];

    // ================================================================
    // EVALUATE — check if business goals are met
    // ================================================================
    evaluate [
        shape=diamond
        label="Goals\nMet?"
        handler="conditional"
    ];

    validate -> evaluate [label="validated"];

    // All goals met -> close
    evaluate -> close [
        label="goals met"
        condition="$last_status = 'success'"
        color=green
        style=bold
    ];

    // Goals not met, cycles remaining -> loop back with failure context
    evaluate -> research [
        label="iterate\n(cycle back)"
        condition="$last_status = 'failure'"
        color=orange
        loop_restart=true
    ];

    // ================================================================
    // EXIT
    // ================================================================
    close [
        shape=Msquare
        label="CLOSE\n{{ initiative_id }}"
        handler="close"
        status="pending"
        style=filled
        fillcolor=lightyellow
    ];
}