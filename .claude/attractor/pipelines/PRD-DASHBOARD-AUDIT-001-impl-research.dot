digraph PRD_DASHBOARD_AUDIT_001_impl_research {

    node [shape=ellipse, style=filled, fillcolor=lightblue];
    edge [arrowhead=vee, color=gray];

    # =========================================================================
    # Research-Refine Pipeline: Validate Both SDs Before Dashboard Implementation
    # SD-DASHBOARD-AUDIT-001 (backend) + SD-SEQ-PERSTEP-TASKS-001 (per-step tasks)
    # =========================================================================

    start [
        label="Start Research"
        handler="start"
        shape=Mdiamond
        fillcolor="lightgreen"
        status="validated"
        style="filled"
    ];

    # =========================================================================
    # Research 1: Backend SD alignment — case_reference vs case_id
    # =========================================================================
    research_backend_sd [
        label="Research: Backend SD case_reference vs case_id"
        handler="research"
        shape=tab
        fillcolor="palegreen"
        status="validated"
        worker_type="researcher"
        llm="haiku"
        sd_path="docs/sds/dashboard-audit-trail/SD-DASHBOARD-AUDIT-001.md"
        prd_ref="PRD-DASHBOARD-AUDIT-001"
        target_dir="/Users/theb/Documents/Windsurf/zenagent3/zenagent/agencheck/agencheck-support-agent"
        project_bank="claude-code-agencheck"
        prompt="Search codebase for all references to case_reference in agencheck-support-agent. Check the cases table schema: does case_reference column exist? Check GET /api/v1/cases/ endpoints — what parameter do they accept (case_id integer vs case_reference string)? Check frontend API calls — does it use case_id integer? Determine: should SD-DASHBOARD-AUDIT-001 drop PG sequence + case_reference column and use cases.id directly?"
        style="filled"
    ];

    # =========================================================================
    # Research 2: Per-step task creation patterns in verification_orchestrator
    # =========================================================================
    research_perstep [
        label="Research: Orchestrator Per-Step Task Creation"
        handler="research"
        shape=tab
        fillcolor="palegreen"
        status="validated"
        worker_type="researcher"
        llm="haiku"
        sd_path="docs/sds/sequence-progression/SD-SEQ-PERSTEP-TASKS-001.md"
        prd_ref="PRD-SEQ-PROGRESSION-001"
        target_dir="/Users/theb/Documents/Windsurf/zenagent3/zenagent/agencheck/agencheck-support-agent"
        project_bank="claude-code-agencheck"
        prompt="Read verification_orchestrator.py step loop — how does it iterate steps? Where is asyncio.sleep? What task_id flows to dispatch? Read channel_dispatch.py — how does task_id reach email verify-check URL? Read background_task_helpers.py — does create_retry_task handle previous_task_id/next_task_id chaining? Check if sequence_advancement.py in support-agent/ is importable from agencheck-support-agent. Search for TERMINAL_CASE_STATUSES or equivalent terminal status values."
        style="filled"
    ];

    # =========================================================================
    # Research 3: Gap analysis alignment — retry loop gaps vs dashboard PRD
    # =========================================================================
    research_gaps [
        label="Research: Gap Analysis Cross-Reference"
        handler="research"
        shape=tab
        fillcolor="palegreen"
        status="accepted"
        worker_type="researcher"
        llm="haiku"
        sd_path="docs/sds/sequence-progression/SD-SEQ-RETRY-LOOP-GAPS-001.md"
        prd_ref="PRD-DASHBOARD-AUDIT-001"
        target_dir="/Users/theb/Documents/Windsurf/zenagent3/zenagent/agencheck/agencheck-support-agent"
        project_bank="claude-code-agencheck"
        prompt="Gap A: Is prefect_bridge.py targeting verification-orchestrator or voice-verification? Check VOICE_VERIFICATION_DEPLOYMENT. Gap B: How many background_check_sequence rows exist? Duplicates? Gap F: In work_history.py ~line 828 is action_type still hardcoded to call_attempt? Check GET /api/v1/verifications endpoint — what fields does it return? What is the frontend route for viewing a case?"
        style="filled"
    ];

    # =========================================================================
    # Research 4: Frontend case detail page current state
    # =========================================================================
    research_frontend [
        label="Research: Frontend Case Detail Page"
        handler="research"
        shape=tab
        fillcolor="palegreen"
        status="validated"
        worker_type="researcher"
        llm="haiku"
        sd_path="docs/sds/dashboard-audit-trail/SD-DASHBOARD-AUDIT-FRONTEND-001.md"
        prd_ref="PRD-DASHBOARD-AUDIT-001"
        target_dir="/Users/theb/Documents/Windsurf/zenagent3/zenagent/agencheck/agencheck-support-frontend"
        project_bank="claude-code-agencheck"
        prompt="Find the case detail page component — route, data fetching. Find RequestsTable or verifications list — columns, case_id display. Search for timeline or stepper components. Check API client (work-history.ts) — endpoints and types. Search for StatusLabel or status display patterns."
        style="filled"
    ];

    # =========================================================================
    # Refine 1: Update backend SD with codebase findings
    # =========================================================================
    refine_backend_sd [
        label="Refine: Update Backend SD"
        handler="refine"
        shape=component
        fillcolor="palegreen"
        status="accepted"
        worker_type="refiner"
        llm="sonnet"
        sd_path="docs/sds/dashboard-audit-trail/SD-DASHBOARD-AUDIT-001.md"
        prd_ref="PRD-DASHBOARD-AUDIT-001"
        project_bank="claude-code-agencheck"
        prompt="Update SD-DASHBOARD-AUDIT-001.md: 1) Replace case_reference with case_id if research confirms integer PK. 2) Update API endpoints to match actual routes. 3) Incorporate gap findings (deployment, sequence rows, action_type). 4) Align timeline API contract with per-step task creation. 5) Update StatusLabelMapper with actual status values."
        style="filled"
    ];

    # =========================================================================
    # Refine 2: Update per-step tasks SD with orchestrator findings
    # =========================================================================
    refine_perstep_sd [
        label="Refine: Update Per-Step Tasks SD"
        handler="refine"
        shape=component
        fillcolor="palegreen"
        status="accepted"
        worker_type="refiner"
        llm="sonnet"
        sd_path="docs/sds/sequence-progression/SD-SEQ-PERSTEP-TASKS-001.md"
        prd_ref="PRD-SEQ-PROGRESSION-001"
        project_bank="claude-code-agencheck"
        prompt="Update SD-SEQ-PERSTEP-TASKS-001.md: 1) Incorporate exact function signatures from verification_orchestrator.py. 2) Clarify sequence_advancement.py reachability. 3) Update target flow with actual asyncio.sleep and task_id threading. 4) Add terminal status guard with actual values. 5) Align create_step_task INSERT with actual background_tasks schema."
        style="filled"
    ];

    # =========================================================================
    # Exit
    # =========================================================================
    complete [
        label="Research Complete"
        handler="exit"
        shape=Msquare
        fillcolor="palegreen"
        status="accepted"
        style="filled"
    ];

    # =========================================================================
    # Execution flow
    # =========================================================================
    start -> research_backend_sd [label="initiates"];
    start -> research_perstep [label="initiates"];
    start -> research_gaps [label="initiates"];
    start -> research_frontend [label="initiates"];

    research_backend_sd -> refine_backend_sd [label="findings"];
    research_gaps -> refine_backend_sd [label="gap_findings"];
    research_frontend -> refine_backend_sd [label="frontend_state"];

    research_perstep -> refine_perstep_sd [label="findings"];
    research_gaps -> refine_perstep_sd [label="gap_findings"];

    refine_backend_sd -> complete [label="refined"];
    refine_perstep_sd -> complete [label="refined"];

    # =========================================================================
    # Metadata
    # =========================================================================
    graph [
        label="PRD-DASHBOARD-AUDIT-001: Implementation Research + Refine (both SDs)"
        labelloc=top
        fontname="Helvetica"
        fontsize=12
    ];
}
