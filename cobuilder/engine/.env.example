# CoBuilder Engine Environment Configuration
# Copy this file to .env and fill in your values

# Anthropic API Configuration
# For DASHSCOPE compatibility, use their Anthropic-compatible endpoint
export ANTHROPIC_BASE_URL="https://api.anthropic.com"
export ANTHROPIC_API_KEY=your-api-key-here
export ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# DASHSCOPE Configuration (if using Aliyun DashScope)
# export ANTHROPIC_BASE_URL="https://coding-intl.dashscope.aliyuncs.com/apps/anthropic"
# export DASHSCOPE_API_KEY=your-dashscope-api-key-here
# export ANTHROPIC_API_KEY=$DASHSCOPE_API_KEY
# export ANTHROPIC_MODEL="qwen3-coder-plus"

# Rate Limit Retry Configuration
# RETRIES=1 to disable, BACKOFF=0 to skip sleep
export PIPELINE_RATE_LIMIT_RETRIES=3
export PIPELINE_RATE_LIMIT_BACKOFF=65